# Gemini API Key configuration
# GEMINI_API_KEY=your-gemini-api-key-here

# Firebase Admin SDK Configuration
# Set to 'true' to enable Firebase replication for live matches
USE_FIREBASE=false
FIREBASE_PROJECT_ID=your-project-id

# Path to the JSON service account key downloaded from Firebase Console Settings -> Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY=app/serviceAccountKey.json
